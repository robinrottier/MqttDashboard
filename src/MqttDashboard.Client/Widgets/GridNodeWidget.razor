@using MqttDashboard.Models
@using MqttDashboard.Services
@using Blazor.Diagrams.Components.Renderers
@inherits BaseNodeWidget<GridNodeModel>

<div style="@ContainerStyle()"
     class=@("pa-1 default-node grid-node" + (Node.Group != null ? " grouped" : "") + (Node.Selected ? " selected" : ""))
     @ondblclick="OnDoubleClick">
    <div style="display:flex;flex-direction:column;height:100%;overflow:hidden;min-width:0;">
        @if (!string.IsNullOrEmpty(Node.Title))
        {
            <div style="font-size:0.75rem;font-weight:500;padding:2px 4px 0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                @Node.Title
            </div>
        }
        <div style="flex:1;overflow:auto;min-height:0;min-width:0;">
            <MudSimpleTable Dense="true" Hover="false" Striped="true" Bordered="false"
                            Style="font-size:0.75rem;width:100%;table-layout:fixed;"
                            Class="pa-0">
                <thead>
                    <tr>
                        <th style="white-space:nowrap;max-width:6rem;">Label</th>
                        @foreach (var header in Node.ColumnHeaders)
                        {
                            <th style="white-space:nowrap;">@header</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (Node.Rows.Count == 0)
                    {
                        <tr>
                            <td colspan="@(Node.ColumnHeaders.Count + 1)" style="opacity:0.5;font-style:italic;">No rows configured</td>
                        </tr>
                    }
                    else
                    {
                        @for (int r = 0; r < Node.Rows.Count; r++)
                        {
                            var row = Node.Rows[r];
                            <tr>
                                <td style="font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@row.Label</td>
                                @for (int c = 0; c < Node.ColumnHeaders.Count; c++)
                                {
                                    var val = GetCellValue(r, c);
                                    <td style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@val</td>
                                }
                            </tr>
                        }
                    }
                </tbody>
            </MudSimpleTable>
        </div>
    </div>
    @foreach (var port in Node.Ports)
    {
        <PortRenderer @key="port" Port="port" Style="@PortStyle(port as MudPortModel)" />
    }
</div>

@code {
    // Keyed by "r{rowIndex}:c{colIndex}" → current MQTT value string.
    // Dictionary is replaced atomically (never mutated from multiple threads at once)
    // so the render loop never races with an incoming MQTT value.
    private Dictionary<string, string> _cellValues = new();
    private readonly List<IDisposable> _watchers = [];
    private bool _disposed;

    protected override void OnInitialized()
    {
        Node.MinimumDimensions = new(160, 80);
        if (Node.Size == null || Node.Size.Width < 160 || Node.Size.Height < 80)
            Node.Size = new(260, 160);
        base.OnInitialized();
        SetupWatchers();
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        SetupWatchers();
    }

    private void SetupWatchers()
    {
        foreach (var w in _watchers) w.Dispose();
        _watchers.Clear();
        _cellValues = new();

        for (int r = 0; r < Node.Rows.Count; r++)
        {
            var row = Node.Rows[r];
            for (int c = 0; c < Node.ColumnHeaders.Count; c++)
            {
                var topic = c < row.Topics.Count ? row.Topics[c] : null;
                if (string.IsNullOrEmpty(topic)) continue;

                var capturedKey = CellKey(r, c);
                var capturedTopic = topic;

                var initial = AppState.DataCache.GetValue(capturedTopic);
                if (initial != null)
                    _cellValues[capturedKey] = initial.ToString() ?? "";

                var watcher = AppState.DataCache.Watch(capturedTopic, (_, value) =>
                {
                    if (_disposed) return;
                    _cellValues[capturedKey] = value?.ToString() ?? "";
                    try { InvokeAsync(StateHasChanged); } catch { }
                });
                _watchers.Add(watcher);
            }
        }
    }

    private static string CellKey(int row, int col) => $"r{row}:c{col}";

    private string GetCellValue(int row, int col)
        => _cellValues.TryGetValue(CellKey(row, col), out var v) ? v : "—";

    public override void Dispose()
    {
        _disposed = true;
        foreach (var w in _watchers) w.Dispose();
        _watchers.Clear();
        base.Dispose();
    }
}
