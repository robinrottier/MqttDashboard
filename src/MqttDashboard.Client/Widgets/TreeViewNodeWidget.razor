@using MqttDashboard.Models
@using MqttDashboard.Services
@using Blazor.Diagrams.Components.Renderers
@inherits BaseNodeWidget<TreeViewNodeModel>

<div style="@ContainerStyle()"
     class=@("pa-1 default-node treeview-node"+(Node.Group!=null?" grouped":"")+(Node.Selected?" selected":""))
     @ondblclick="OnDoubleClick">
    <div style="display:flex;flex-direction:column;height:100%;overflow:hidden;min-width:0;">
        @if (!string.IsNullOrEmpty(Node.Title))
        {
            <div style="font-size:0.75rem;font-weight:500;padding:2px 4px 0;">@Node.Title</div>
        }
        @if (string.IsNullOrEmpty(Node.RootTopic))
        {
            <div style="opacity:0.5;font-size:0.75rem;padding:4px;">Set Root Topic in properties.</div>
        }
        else
        {
            <div style="flex:1;overflow-y:auto;font-size:0.75rem;min-height:0;padding:2px 0;">
                <MudTreeView T="TreeNode" Dense="true" Hover="true"
                             Style="font-size:0.75rem;font-family:monospace;overflow:auto;width:100%;height:100%;">
                    @RenderMudTreeItem(_tree)
                </MudTreeView>
            </div>
        }
    </div>
    @foreach (var port in Node.Ports)
    {
        <PortRenderer @key="port" Port="port" Style="@PortStyle(port as MudPortModel)" />
    }
</div>

@code {
    private TreeNode _tree = new("", "");
    private bool _disposed;
    private IDisposable? _watchSubscription;
    private IDisposable? _rootWatchSubscription;
    private readonly Dictionary<string, bool> _expandedState = new();
    private readonly Dictionary<string, DateTime> _changedAt = new();

    private sealed class TreeNode(string fullTopic, string label)
    {
        public string FullTopic { get; } = fullTopic;
        public string Label { get; } = label;
        public string? Value { get; set; }
        public List<TreeNode> Children { get; set; } = [];
        public bool Expanded { get; set; } = true;
    }

    protected override void OnInitialized()
    {
        Node.MinimumDimensions = new(120, 80);
        if (Node.Size == null || Node.Size.Width < 120 || Node.Size.Height < 80)
            Node.Size = new(200, 200);
        base.OnInitialized();
        SetupWatchers();
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        SetupWatchers();
    }

    private void SetupWatchers()
    {
        _watchSubscription?.Dispose(); _watchSubscription = null;
        _rootWatchSubscription?.Dispose(); _rootWatchSubscription = null;

        if (string.IsNullOrEmpty(Node.RootTopic)) { _tree = new("", ""); return; }

        RebuildTree();

        var wildcardTopic = Node.RootTopic.TrimEnd('/') + "/#";
        _watchSubscription = AppState.DataCache.Watch(wildcardTopic, OnTopicChanged);
        _rootWatchSubscription = AppState.DataCache.Watch(Node.RootTopic, OnTopicChanged);
    }

    private void OnTopicChanged(string topic, object value)
    {
        if (_disposed) return;
        _changedAt[topic] = DateTime.Now;
        var node = FindNode(_tree, topic);
        if (node != null)
        {
            node.Value = value?.ToString();
        }
        else
        {
            SaveExpansionState(_tree);
            RebuildTree();
            RestoreExpansionState(_tree);
        }
        try { InvokeAsync(StateHasChanged); } catch { }
    }

    private void RebuildTree()
    {
        if (string.IsNullOrEmpty(Node.RootTopic)) { _tree = new("", ""); return; }

        var root = new TreeNode(Node.RootTopic, Node.RootTopic.Split('/').Last());
        root.Value = AppState.DataCache.GetValue(Node.RootTopic)?.ToString();
        root.Expanded = true;

        var pattern = Node.RootTopic.TrimEnd('/') + "/#";
        var matches = AppState.DataCache.GetValuesByPattern(pattern);

        foreach (var kvp in matches.OrderBy(x => x.Key))
        {
            var relativeParts = kvp.Key.Substring(Node.RootTopic.Length).TrimStart('/').Split('/');
            var node = root;
            var currentPath = Node.RootTopic;
            var depth = 0;
            foreach (var part in relativeParts)
            {
                currentPath += "/" + part;
                depth++;
                var child = node.Children.FirstOrDefault(c => c.Label == part);
                if (child == null)
                {
                    child = new TreeNode(currentPath, part) { Expanded = depth <= 1 };
                    node.Children.Add(child);
                }
                node = child;
            }
            node.Value = kvp.Value?.ToString();
        }
        _tree = root;
    }

    private void SaveExpansionState(TreeNode node)
    {
        _expandedState[node.FullTopic] = node.Expanded;
        foreach (var child in node.Children)
            SaveExpansionState(child);
    }

    private void RestoreExpansionState(TreeNode node)
    {
        if (_expandedState.TryGetValue(node.FullTopic, out var expanded))
            node.Expanded = expanded;
        foreach (var child in node.Children)
            RestoreExpansionState(child);
    }

    private TreeNode? FindNode(TreeNode node, string fullTopic)
    {
        if (node.FullTopic == fullTopic) return node;
        foreach (var child in node.Children)
        {
            var found = FindNode(child, fullTopic);
            if (found != null) return found;
        }
        return null;
    }

    private RenderFragment RenderMudTreeItem(TreeNode node) => builder =>
    {
        var isHighlighted = _changedAt.TryGetValue(node.FullTopic, out var changedTime) &&
                            (DateTime.Now - changedTime).TotalSeconds < 2;

        builder.OpenComponent<MudTreeViewItem<TreeNode>>(0);
        builder.AddAttribute(1, "Value", node);
        builder.AddAttribute(2, "Expanded", node.Expanded);
        builder.AddAttribute(3, "ExpandedChanged", EventCallback.Factory.Create<bool>(this, v => node.Expanded = v));

        var displayText = node.Children.Count > 0
            ? node.Label
            : (Node.ShowValues && node.Value != null ? $"{node.Label}: {node.Value}" : node.Label);
        builder.AddAttribute(4, "Text", displayText);

        if (isHighlighted)
            builder.AddAttribute(5, "Style", "background:var(--mud-palette-warning-hover);");

        if (node.Children.Count > 0)
        {
            builder.AddAttribute(6, "ChildContent", (RenderFragment)(childBuilder =>
            {
                foreach (var child in node.Children)
                    childBuilder.AddContent(0, RenderMudTreeItem(child));
            }));
        }

        builder.CloseComponent();
    };

    public override void Dispose()
    {
        _disposed = true;
        _watchSubscription?.Dispose();
        _rootWatchSubscription?.Dispose();
        base.Dispose();
    }
}
