@page "/edit"
@rendermode InteractiveAuto
@using Blazor.Diagrams;
@using Blazor.Diagrams.Components
@using Blazor.Diagrams.Components.Widgets
@using Blazor.Diagrams.Core.Models
@using BlazorApp1.Components

<PageTitle>@(AppState.DisplayName) - Edit</PageTitle>

@if (!AppState.IsInteractive || _diagram == null)
{
    <MudStack AlignItems="AlignItems.Center" Class="mt-8">
        <MudProgressCircular Indeterminate="true" />
        <MudText>Loading&hellip;</MudText>
    </MudStack>
}
else
{
    <MudPaper Elevation="2" Style="width:100%; height:calc(100vh - 80px);">
        <CascadingValue Value="_diagram" IsFixed="true">
            <DiagramCanvas>
                <Widgets>
                    @if (_diagram?.Options.GridSize != null)
                    {
                        <GridWidget Size="@(_diagram.Options.GridSize ?? 20)"
                                    Mode="GridMode.Line"
                                    BackgroundColor="white" />
                    }
                </Widgets>
            </DiagramCanvas>
        </CascadingValue>
    </MudPaper>
}

