@using MqttDashboard.Models
@using MqttDashboard.Services
@using Blazor.Diagrams.Components.Renderers
@inherits BaseNodeWithDataWidget<BatteryNodeModel>

<MudTooltip Delay="500" Arrow="true" Placement="Placement.Top">
    <TooltipContent>
        @if (!string.IsNullOrEmpty(Node.DataTopic))
        {
            <div>
                <strong>Topic:</strong> @Node.DataTopic<br/>
                <strong>Value:</strong> @(Node.DataValue?.ToString() ?? "—")<br/>
                <strong>Updated:</strong> @(Node.DataLastUpdated.HasValue ? Node.DataLastUpdated.Value.ToString("HH:mm:ss") : "—")
            </div>
        }
        else { <span>No data topic configured</span> }
    </TooltipContent>
    <ChildContent>
        <div style="@ContainerStyle()"
             class=@("pa-1 default-node battery-node"+(Node.Group != null ? " grouped" : "")+(Node.Selected ? " selected" : ""))
             @ondblclick="OnDoubleClick">
            <div style="@OuterFlexStyle()">
                @if (ShowTitleFirst())
                {
                    <div style="@TitleDivStyle()">@Node.Title</div>
                }
                <div style="flex:1;min-height:0;min-width:0;display:flex;flex-direction:column;align-items:center;justify-content:center;">
                    <!-- Battery SVG: terminal nub on top, body below, fill from bottom -->
                    <svg viewBox="0 0 40 70" style="width:auto;height:80%;max-height:60px;display:block;">
                        <!-- Terminal nub -->
                        <rect x="13" y="0" width="14" height="5" rx="2" fill="currentColor" opacity="0.6"/>
                        <!-- Battery body outline -->
                        <rect x="3" y="5" width="34" height="60" rx="4" stroke="currentColor" stroke-width="2.5" fill="none"/>
                        <!-- Fill level (from bottom up) -->
                        @{
                            var fillH = (int)(54 * Math.Clamp(_percent, 0.0, 1.0));
                            var fillY = 59 - fillH;
                        }
                        @if (fillH > 0)
                        {
                            <rect x="5" y="@fillY" width="30" height="@fillH" rx="2" fill="@GetFillColor()"/>
                        }
                        <!-- Percentage text centred in battery -->
                        @((MarkupString)$"<text x=\"20\" y=\"40\" text-anchor=\"middle\" dominant-baseline=\"middle\" font-size=\"14\" font-weight=\"bold\" fill=\"currentColor\">{FormatPercent()}</text>")
                    </svg>
                    @if (!string.IsNullOrEmpty(Node.Text))
                    {
                        <div style="text-align:center;font-size:0.7rem;padding:1px 2px;word-break:break-word;">@FormatText()</div>
                    }
                </div>
                @if (!ShowTitleFirst() && !string.IsNullOrEmpty(Node.Title))
                {
                    <div style="@TitleDivStyle()">@Node.Title</div>
                }
            </div>
            @foreach (var port in Node.Ports)
            {
                <PortRenderer @key="port" Port="port" Style="@PortStyle(port as MudPortModel)" />
            }
        </div>
    </ChildContent>
</MudTooltip>

@code {
    private double _percent = 0;

    // Returns the value that drives the fill level, honoring DataTopicIndex.
    private object? ActiveValue => Node.DataTopicIndex == 1 ? Node.DataValue2 : Node.DataValue;
    // Returns the value used for color threshold evaluation, honoring BatteryColor.ColorTopicIndex.
    private object? ColorValue  => Node.BatteryColor.ColorTopicIndex == 1 ? Node.DataValue2 : Node.DataValue;

    protected override void OnInitialized()
    {
        Node.MinimumDimensions = new(50, 70);
        if (Node.Size == null || Node.Size.Width < 50 || Node.Size.Height < 70)
            Node.Size = new(80, 110);
        base.OnInitialized();
    }

    protected override void OnData1Updated() => UpdatePercent();
    protected override void OnData2Updated() => UpdatePercent();

    private void UpdatePercent()
    {
        if (ActiveValue == null) { _percent = 0; return; }
        if (double.TryParse(ActiveValue.ToString(), out var d))
        {
            var range = Node.MaxValue - Node.MinValue;
            _percent = range == 0 ? 0 : Math.Clamp((d - Node.MinValue) / range, 0.0, 1.0);
        }
    }

    private string GetFillColor()
    {
        if (Node.BatteryColor.ColorThresholds.Count > 0)
        {
            var pct = _percent * 100;
            var cv = ColorValue;
            double colorDouble = cv != null && double.TryParse(cv.ToString(), out var parsed) ? parsed : pct;
            string? color = null;
            foreach (var t in Node.BatteryColor.ColorThresholds)
            {
                if (t.Direction == ">=" && colorDouble >= t.Value) color = t.Color;
                else if (t.Direction == "<=" && colorDouble <= t.Value) color = t.Color;
            }
            if (color != null) return color;
        }
        return "var(--mud-palette-primary)";
    }

    private string FormatPercent()
    {
        if (!Node.ShowPercent || ActiveValue == null) return "";
        if (double.TryParse(ActiveValue.ToString(), out _))
        {
            var pct = (int)Math.Round(_percent * 100);
            return $"{pct}%";
        }
        return "";
    }

    private string TitlePos => string.IsNullOrEmpty(Node.TitlePosition) ? "Above" : Node.TitlePosition;
    private bool ShowTitleFirst() => (TitlePos == "Above" || TitlePos == "Left") && !string.IsNullOrEmpty(Node.Title);
    private string OuterFlexStyle() => TitlePos switch {
        "Left" or "Right" => "display:flex;flex-direction:row;align-items:center;height:100%;",
        _ => "display:flex;flex-direction:column;height:100%;"
    };
    private string TitleDivStyle() => TitlePos switch {
        "Left" or "Right" => "text-align:center;font-size:0.75rem;font-weight:500;padding:2px 4px;max-width:4rem;word-wrap:break-word;",
        _ => "text-align:center;font-size:0.75rem;font-weight:500;padding:2px 4px 0;"
    };
}
