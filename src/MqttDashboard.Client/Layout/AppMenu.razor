@using MqttDashboard.Services
@using MqttDashboard.Models
@using Blazor.Diagrams.Core.Models
@using MqttDashboard.Components
@inject ApplicationState AppState
@inject NavigationManager Nav
@inject IDialogService DialogService
@implements IDisposable

<MudMenu Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">

    <!-- File menu: always a submenu; recent files + More... in both modes -->
    <MudMenu Label="File" Dense="true" AnchorOrigin="Origin.TopLeft" TransformOrigin="Origin.TopRight">
        @if (IsEditMode)
        {
            <MudMenuItem Label="New" OnClick="NewDiagram" />
        }
        <MudMenuItem Label="Open…" OnClick="OpenDiagram" />
        @if (IsEditMode)
        {
            <MudMenuItem Label="Reload from Disk" OnClick="ReloadDiagram" />
            <MudDivider />
            <MudMenuItem Label="Save" Disabled="@string.IsNullOrEmpty(AppState.DashboardName)" OnClick="SaveDashboard" />
            <MudMenuItem Label="Save As…"             OnClick="SaveAsDiagram"          />
            <MudDivider />
            <MudMenuItem Label="Dashboard Properties…"  OnClick="MenuDiagramProperties"  />
            @if (AppState.IsEditMode)
            {
                <MudDivider />
                <MudMenuItem Label="Export…" OnClick="MenuExportNodes" />
                <MudMenuItem Label="Import…" OnClick="MenuImportNodes" />
            }
            @if (AppState.IsEditMode)
            {
                <MudDivider />
                <MudMenuItem OnClick="@(() => AppState.TriggerAddPage())">Add Page</MudMenuItem>
                @for (int i = 0; i < AppState.PageNames.Count; i++)
                {
                    var idx = i;
                    <MudMenuItem OnClick="@(() => AppState.TriggerSetActivePage(idx))"
                                 Disabled="@(AppState.ActivePageIndex == idx)">
                        @(AppState.ActivePageIndex == idx ? "▶ " : "")Go to: @AppState.PageNames[idx]
                    </MudMenuItem>
                }
            }
        }
    </MudMenu>

    <!-- Edit: only shown in edit mode -->
    @if (IsEditMode)
    {
    <MudMenu Label="Edit" Dense="true" AnchorOrigin="Origin.TopLeft" TransformOrigin="Origin.TopRight">
        <MudMenuItem Label="Undo"     OnClick="Undo"     Disabled="@(!AppState.CanUndo)" />
        <MudMenuItem Label="Redo"     OnClick="Redo"     Disabled="@(!AppState.CanRedo)" />
        <MudMenuItem Label="Undo All" OnClick="UndoAll"  Disabled="@(!AppState.CanUndo)" />
        <MudDivider />
        <MudMenuItem Label="Add Node"    OnClick="MenuAddNode"    Disabled="@(!IsEditMode)" />
        <MudMenuItem Label="Delete Node" OnClick="MenuDeleteNode" Disabled="@(!AppState.HasSelectedNode)" />
        <MudDivider />
        <MudMenuItem Label="Cut"   OnClick="MenuCutSelected"  Disabled="@(!AppState.HasSelectedNode)" />
        <MudMenuItem Label="Copy"  OnClick="MenuCopySelected" Disabled="@(!AppState.HasSelectedNode)" />
        <MudMenuItem Label="Paste" OnClick="MenuPasteSelected" Disabled="@(!AppState.HasClipboard || !IsEditMode)" />
        <MudDivider />
        <MudMenu Label="Add Port"    Dense="true" AnchorOrigin="Origin.TopLeft" TransformOrigin="Origin.TopRight" Disabled="@(!AppState.HasSingleSelectedNode)">
            <MudMenuItem Label="Top"    OnClick="() => MenuAddPort(PortAlignment.Top)"    Disabled="@(AppState.SelectedNodePorts?.Contains(PortAlignment.Top) == true)" />
            <MudMenuItem Label="Left"   OnClick="() => MenuAddPort(PortAlignment.Left)"   Disabled="@(AppState.SelectedNodePorts?.Contains(PortAlignment.Left) == true)" />
            <MudMenuItem Label="Bottom" OnClick="() => MenuAddPort(PortAlignment.Bottom)" Disabled="@(AppState.SelectedNodePorts?.Contains(PortAlignment.Bottom) == true)" />
            <MudMenuItem Label="Right"  OnClick="() => MenuAddPort(PortAlignment.Right)"  Disabled="@(AppState.SelectedNodePorts?.Contains(PortAlignment.Right) == true)" />
            <MudDivider />
            <MudMenuItem Label="All"    OnClick="MenuAddAllPorts" Disabled="@(AppState.SelectedNodePorts?.Count == 4)" />
        </MudMenu>
        <MudMenu Label="Delete Port" Dense="true" AnchorOrigin="Origin.TopLeft" TransformOrigin="Origin.TopRight" Disabled="@(!AppState.HasSingleSelectedNode)">
            <MudMenuItem Label="Top"    OnClick="() => MenuDeletePort(PortAlignment.Top)"    Disabled="@(AppState.SelectedNodePorts?.Contains(PortAlignment.Top) != true)" />
            <MudMenuItem Label="Left"   OnClick="() => MenuDeletePort(PortAlignment.Left)"   Disabled="@(AppState.SelectedNodePorts?.Contains(PortAlignment.Left) != true)" />
            <MudMenuItem Label="Bottom" OnClick="() => MenuDeletePort(PortAlignment.Bottom)" Disabled="@(AppState.SelectedNodePorts?.Contains(PortAlignment.Bottom) != true)" />
            <MudMenuItem Label="Right"  OnClick="() => MenuDeletePort(PortAlignment.Right)"  Disabled="@(AppState.SelectedNodePorts?.Contains(PortAlignment.Right) != true)" />
        </MudMenu>
        <MudDivider />
        <MudMenuItem Label="Properties" OnClick="MenuEditProperties" Disabled="@(!AppState.HasSingleSelectedNode)" />
    </MudMenu>
    }

    <!-- Options (before About) -->
    <MudMenu Label="Options" Dense="true" AnchorOrigin="Origin.TopLeft" TransformOrigin="Origin.TopRight">
        <MudMenu Label="Theme" Dense="true" AnchorOrigin="Origin.TopLeft" TransformOrigin="Origin.TopRight">
            <MudMenuItem OnClick="() => SetTheme(ThemeMode.Light)">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Style="@(AppState.ThemeMode == ThemeMode.Light ? "" : "visibility:hidden")" />
                    <MudText>Light</MudText>
                </MudStack>
            </MudMenuItem>
            <MudMenuItem OnClick="() => SetTheme(ThemeMode.Dark)">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Style="@(AppState.ThemeMode == ThemeMode.Dark ? "" : "visibility:hidden")" />
                    <MudText>Dark</MudText>
                </MudStack>
            </MudMenuItem>
            <MudMenuItem OnClick="() => SetTheme(ThemeMode.Auto)">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Style="@(AppState.ThemeMode == ThemeMode.Auto ? "" : "visibility:hidden")" />
                    <MudText>Auto</MudText>
                </MudStack>
            </MudMenuItem>
        </MudMenu>
        @if (AppState.AuthEnabled && AppState.IsAdmin)
        {
            <MudDivider />
            <MudMenuItem OnClick='() => Nav.NavigateTo("/change-password")'>Change Password…</MudMenuItem>
            <MudMenuItem OnClick="ShowStartupSettings">Startup Settings…</MudMenuItem>
        }
    </MudMenu>

    <!-- About (last) -->
    <MudMenuItem OnClick="ShowAbout">About</MudMenuItem>

</MudMenu>

@code {
    private bool IsEditMode => AppState.IsEditMode;

    protected override void OnInitialized()
    {
        AppState.OnStateChanged += OnAppStateChanged;
    }

    private void OnAppStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        AppState.OnStateChanged -= OnAppStateChanged;
    }

    private Task ShowAbout() => DialogService.ShowAsync<AboutDialog>("About Mqtt Dashboard",
        new DialogParameters(),
        new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true });
    private Task ShowStartupSettings() => DialogService.ShowAsync<StartupSettingsDialog>("Startup Settings");

    private void NewDiagram()         => AppState.TriggerNewDiagram();
    private void OpenDiagram()        => AppState.TriggerOpen();
    private void SaveDashboard()        => AppState.TriggerSaveDiagram();
    private void SaveAsDiagram()      => AppState.TriggerSaveAs();
    private void ReloadDiagram()          => AppState.TriggerReloadDiagram();
    private void MenuDiagramProperties()  => AppState.TriggerDiagramProperties();
    private void Undo()               => AppState.TriggerUndo();
    private void Redo()               => AppState.TriggerRedo();
    private void UndoAll()            => AppState.TriggerUndoAll();
    private void MenuAddNode()        => AppState.TriggerAddNode();
    private void MenuDeleteNode()     => AppState.TriggerDeleteNode();
    private void MenuCutSelected()    => AppState.TriggerCutSelected();
    private void MenuCopySelected()   => AppState.TriggerCopySelected();
    private void MenuPasteSelected()  => AppState.TriggerPasteSelected();
    private void MenuExportNodes()    => AppState.TriggerExportNodes();
    private void MenuImportNodes()    => AppState.TriggerImportNodes();
    private void MenuEditProperties() => AppState.TriggerEditProperties();
    private void MenuAddAllPorts()              => AppState.TriggerAddAllPorts();
    private void MenuAddPort(PortAlignment a)    => AppState.TriggerAddPort(a);
    private void MenuDeletePort(PortAlignment a) => AppState.TriggerDeletePort(a);
    private void SetTheme(ThemeMode m)  => AppState.SetTheme(m);
}
