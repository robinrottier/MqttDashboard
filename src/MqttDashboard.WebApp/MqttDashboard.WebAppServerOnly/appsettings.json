{
  "ReadOnly": false,
  "ReadOnlyPorts": "",
  "App": {
    "MaxMessageHistory": 500,
    "AutoSaveOnExit": false
  },
  "Auth": {
    "AdminPasswordHash": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
