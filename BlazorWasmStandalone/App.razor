<Router AppAssembly="@typeof(App).Assembly" NotFoundPage="typeof(MqttDashboard.Pages.NotFound)"
        AdditionalAssemblies="@(new[] { typeof(MqttDashboard._Imports).Assembly })">

    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MqttDashboard.Layout.MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
</Router>
