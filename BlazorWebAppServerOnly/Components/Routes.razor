<Router AppAssembly="typeof(Program).Assembly" NotFoundPage="typeof(BlazorApp1.Pages.NotFound)"
        AdditionalAssemblies="@(new[] { typeof(BlazorApp1._Imports).Assembly })">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(BlazorApp1.Layout.MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>
