@inherits LayoutComponentBase
@implements IDisposable
@using MqttDashboard.Services
@using MqttDashboard.Models
@using System.Reflection
@inject MqttInitializationService MqttInit
@inject ApplicationState AppState
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject HttpClient Http
<MudThemeProvider Theme="@_theme" IsDarkMode="@ComputedDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="false">
        <!-- Diagram icon -->
        <MudIconButton Icon="@Icons.Material.Filled.AccountTree" Color="Color.Primary" Size="Size.Large" Class="mr-2"
                       OnClick='() => Nav.NavigateTo("/")' />

        <!-- App name + optional diagram name -->
        <MudText Typo="Typo.h6" Class="d-flex align-center gap-2">
            @AppName
            @if (AppState.IsEditMode || AppState.ShowDiagramName)
            {
                <MudText Typo="Typo.h6" Color="Color.Secondary" Style="display:inline">
                    &mdash; @(string.IsNullOrEmpty(AppState.DiagramName) ? "Untitled" : AppState.DiagramName)
                </MudText>
            }
        </MudText>

        <MudSpacer />

        <!-- MQTT connection status indicator -->
        <MudTooltip Text="@AppState.MqttConnectionStatus">
            <MudIcon Icon="@MqttStatusIcon" Color="@MqttStatusColor" Size="Size.Medium" Class="mr-3" />
        </MudTooltip>

        <!-- Auth: login/logout button when auth is configured -->
        @if (AppState.AuthEnabled)
        {
            @if (AppState.IsAdmin)
            {
                <MudTooltip Text="Logout admin">
                    <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit" Size="Size.Medium"
                                   OnClick="Logout" Class="mr-1" />
                </MudTooltip>
            }
            else
            {
                <MudTooltip Text="Login as admin">
                    <MudIconButton Icon="@Icons.Material.Filled.Login" Color="Color.Warning" Size="Size.Medium"
                                   OnClick='() => Nav.NavigateTo("/login")' Class="mr-1" />
                </MudTooltip>
            }
        }

        <!-- Edit mode toggle switch — hidden when auth is enabled and user is not admin -->
        @if (!AppState.AuthEnabled || AppState.IsAdmin)
        {
        <!-- Edit mode toggle switch -->
        <MudTooltip Text="@(_isEditMode ? "Switch to view mode" : "Switch to edit mode")">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mr-2">
                <MudText Typo="Typo.body2"
                         Style="@(_isEditMode ? "font-weight:700; color: var(--mud-palette-primary);" : "color: var(--mud-palette-text-secondary);")">
                    Edit
                </MudText>
                <MudSwitch Value="_isEditMode"
                           ValueChanged="@((bool v) => ToggleEditMode())"
                           Color="@(AppState.IsEdited ? Color.Warning : Color.Primary)"
                           T="bool" />
            </MudStack>
        </MudTooltip>
        }

        <!-- Hamburger menu button (top-right, 3 bars) -->
        <AppMenu />
    </MudAppBar>

    <MudMainContent Class="pt-16 pa-2">
        @if (_setupNeeded)
        {
            <MudAlert Severity="Severity.Warning" Class="ma-2">
                Admin password not configured. <MudLink Href="/setup">Set up now →</MudLink>
            </MudAlert>
        }
        @if (AppState.UpdateAvailableVersion != null && !_updateDismissed)
        {
            <MudAlert Severity="Severity.Info" Class="ma-2" ShowCloseIcon="true" CloseIconClicked="() => _updateDismissed = true">
                @if (AppState.DeploymentType == "Docker")
                {
                    <MudText>Version <strong>@AppState.UpdateAvailableVersion</strong> is available.
                        Run <code>docker compose pull &amp;&amp; docker compose up -d</code> to update.</MudText>
                }
                else if (AppState.DeploymentType == "HomeAssistant")
                {
                    <MudText>Version <strong>@AppState.UpdateAvailableVersion</strong> is available.
                        Update via the Home Assistant Add-on Store.</MudText>
                }
                else if (AppState.DeploymentType == "Development")
                {
                    <MudText>Running development build <strong>@AppState.CurrentVersion</strong>.</MudText>
                }
                else
                {
                    <MudText>Version <strong>@AppState.UpdateAvailableVersion</strong> is available.
                        <MudLink Href="@AppState.UpdateReleaseUrl" Target="_blank">View release →</MudLink>
                    </MudText>
                }
            </MudAlert>
        }
        @Body
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _systemDarkMode = false;
    private MudTheme? _theme = null;
    private bool _setupNeeded = false;
    private bool _updateDismissed = false;

    private string AppName => GetType().Assembly
        .GetCustomAttribute<System.Reflection.AssemblyProductAttribute>()?.Product
        ?? "Mqtt Dashboard";
    private bool _isEditMode => AppState.IsEditMode;

    private bool ComputedDarkMode => AppState.ThemeMode switch
    {
        ThemeMode.Light => false,
        ThemeMode.Dark  => true,
        _               => _systemDarkMode
    };

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        _theme = new()
        {
            PaletteLight = _lightPalette,
            PaletteDark = _darkPalette,
            LayoutProperties = new LayoutProperties()
        };

        AppState.OnStateChanged += OnAppStateChanged;
        await MqttInit.InitializeAsync(RendererInfo.IsInteractive);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _systemDarkMode = await JS.InvokeAsync<bool>(
                    "eval", "window.matchMedia('(prefers-color-scheme: dark)').matches");
                StateHasChanged();
            }
            catch { /* ignore — JS not available during prerender */ }

            try
            {
                var resp = await Http.GetFromJsonAsync<SetupNeededResponse>("/api/setup/needed");
                if (resp?.Needed == true)
                {
                    _setupNeeded = true;
                    StateHasChanged();
                }
            }
            catch { /* ignore if not available */ }

            // Check for available updates
            try
            {
                var status = await Http.GetFromJsonAsync<UpdateStatusResponse>("/api/update/status");
                if (status != null)
                {
                    AppState.SetUpdateState(status.CurrentVersion, status.LatestVersion,
                        status.UpdateAvailable, status.DeploymentType, status.LastChecked, status.ReleaseUrl);
                    StateHasChanged();
                }
            }
            catch { /* ignore — update check is non-critical */ }
        }
        await base.OnAfterRenderAsync(firstRender);
    }

    private void OnAppStateChanged() => InvokeAsync(StateHasChanged);

    private void ToggleEditMode() => AppState.RequestToggleEditMode();

    [Inject] private IAuthService AuthService { get; set; } = default!;

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        AppState.SetAuthState(false, true);
        Nav.NavigateTo("/login");
    }

    private string MqttStatusIcon =>AppState.IsMqttConnected
        ? Icons.Material.Filled.CloudDone
        : AppState.MqttConnectionStatus.Contains("reconnect", StringComparison.OrdinalIgnoreCase)
            ? Icons.Material.Filled.CloudSync
            : Icons.Material.Filled.CloudOff;

    private Color MqttStatusColor => AppState.IsMqttConnected
        ? Color.Success
        : AppState.MqttConnectionStatus.Contains("reconnect", StringComparison.OrdinalIgnoreCase)
            ? Color.Warning
            : Color.Error;

    public void Dispose()
    {
        AppState.OnStateChanged -= OnAppStateChanged;
    }

    private record SetupNeededResponse(bool Needed);
    private record UpdateStatusResponse(string CurrentVersion, string? LatestVersion, bool UpdateAvailable,
        string DeploymentType, DateTimeOffset? LastChecked, string? ReleaseUrl, string RuntimeIdentifier);

    private readonly PaletteLight _lightPalette = new()
    {
        Black = "#110e2d",
        AppbarText = "#424242",
        AppbarBackground = "rgba(255,255,255,0.8)",
        DrawerBackground = "#ffffff",
        GrayLight = "#e8e8e8",
        GrayLighter = "#f9f9f9",
    };

    private readonly PaletteDark _darkPalette = new()
    {
        Primary = "#7e6fff",
        Surface = "#1e1e2d",
        Background = "#1a1a27",
        BackgroundGray = "#151521",
        AppbarText = "#92929f",
        AppbarBackground = "rgba(26,26,39,0.8)",
        DrawerBackground = "#1a1a27",
        ActionDefault = "#74718e",
        ActionDisabled = "#9999994d",
        ActionDisabledBackground = "#605f6d4d",
        TextPrimary = "#b2b0bf",
        TextSecondary = "#92929f",
        TextDisabled = "#ffffff33",
        DrawerIcon = "#92929f",
        DrawerText = "#92929f",
        GrayLight = "#2a2833",
        GrayLighter = "#1e1e2d",
        Info = "#4a86ff",
        Success = "#3dcb6c",
        Warning = "#ffb545",
        Error = "#ff3f5f",
        LinesDefault = "#33323e",
        TableLines = "#33323e",
        Divider = "#292838",
        OverlayLight = "#1e1e2d80",
    };
}
