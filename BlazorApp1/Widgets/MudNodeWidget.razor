@using Blazor.Diagrams.Components.Renderers;
@using BlazorApp1.Models

<style>
    .mud-node .mud-card {
        width: 100%;
        height: 100%;
        background-color: lightgray;
        border-radius: 8px;
    }

    .mud-node-title-selected {
        font-weight: bold;
    }
</style>

<div class="mud-node default-node @(Node.Selected ? "selected" : "")" style=@GenerateStyle()>

<MudCard Elevation="@(Node.Selected ? 8 : 2)">
    <MudCardHeader Class="@(Node.Selected ? "mud-node-title-selected" : "")">
        @(Node.Title ?? "Title")
    </MudCardHeader>

    @foreach (var port in Node.Ports)
    {
        // In case you have any ports to show
        // IMPORTANT: You are always in charge of rendering ports
        <PortRenderer @key="port" Port="port" />
    }
</MudCard>
</div>

    @code {
    // This gets filled by the library
    [Parameter] public MudNodeModel Node { get; set; } = null!;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        // set min size and default size...
        Node.MinimumDimensions = new(60, 45);
        if (Node.Size == null
         || Node.Size.Width < Node.MinimumDimensions.Width
         || Node.Size.Height < Node.MinimumDimensions.Height)
            Node.Size = new(120, 90);

    }

    // copied from base diagrams NodeWidget.cs ...maybe we shold inherit from it?
    private string GenerateStyle()
    {
        if (Node.Size is not null)
        {
            return $"width: {Node.Size.Width}px; height: {Node.Size.Height}px";
        }
        return string.Empty;
    }
}
