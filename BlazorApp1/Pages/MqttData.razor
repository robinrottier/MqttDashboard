@page "/data"
@using BlazorApp1.Models
@using BlazorApp1.Services
@inject SignalRService SignalRService
@inject ApplicationState AppState
@inject ApplicationStateService AppStateService
@inject MqttInitializationService MqttInit
@inject DiagramService DiagramService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@implements IAsyncDisposable
@implements IDisposable

<PageTitle>@(AppState.DisplayName) - Data</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-2 pa-2">
    <MudGrid Spacing="2">

        <!-- Left: Data Cache Explorer -->
        <MudItem xs="12" md="8">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Data Explorer</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip T="string" Size="Size.Small" Color="Color.Success">
                            @AppState.DataCache.GetAllTopics().Count() Topics
                        </MudChip>
                        <MudIconButton Icon="@(_isDataExplorerExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                       Color="Color.Default"
                                       OnClick="ToggleDataExplorer"
                                       Size="Size.Small"
                                       title="@(_isDataExplorerExpanded ? "Collapse" : "Expand all")" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Style="@GetDataExplorerStyle()">
                    @if (_treeItems != null && _treeItems.Any())
                    {
                        <MudTreeView T="MqttTopicNode"
                                     Items="_treeItems"
                                     Dense="true"
                                     Hover="true"
                                     ExpandOnClick="true">
                            <ItemTemplate Context="item">
                                <MudTreeViewItem @bind-Expanded="@item.Expanded"
                                                 Items="@item.Children"
                                                 Value="@item.Value"
                                                 Icon="@(item.Value?.Icon ?? string.Empty)"
                                                 IconColor="@(item.Value?.IconColor ?? Color.Default)">
                                    <BodyContent>
                                        <div style="display: flex; align-items: center; width: 100%; gap: 4px; cursor: pointer;"
                                             @onclick="async () => await CopyTopicToClipboard(item.Value?.FullPath ?? string.Empty)">
                                            <MudText Typo="Typo.body2" Style="flex: 1;">@item.Value?.Name</MudText>
                                            @if (item.Value?.HasValue == true)
                                            {
                                                <MudText Typo="Typo.body2" Style="min-width: 100px; text-align: right; font-family: monospace;">
                                                    @item.Value.Value?.ToString()
                                                </MudText>
                                                <span @onclick:stopPropagation="true">
                                                    <MudIconButton Size="Size.Small"
                                                                   Icon="@Icons.Material.Filled.Add"
                                                                   title="Add to diagram"
                                                                   OnClick="@(async () => await AddTopicToDiagram(item.Value!.FullPath, item.Value.Name))" />
                                                </span>
                                            }
                                        </div>
                                    </BodyContent>
                                </MudTreeViewItem>
                            </ItemTemplate>
                        </MudTreeView>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">
                            No data in cache yet. Subscribe to topics to see data here.
                        </MudAlert>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Right: Subscriptions + Log -->
        <MudItem xs="12" md="4">
            <MudStack Spacing="2">

                <!-- Subscriptions card -->
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Subscriptions</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Class="pa-0">
                        <MudList T="string" Dense="true">
                            @foreach (var topic in _orderedTopics)
                            {
                                <MudListItem T="string" Dense="true" Class="px-2 py-0">
                                    <div style="display: flex; align-items: center; gap: 2px; width: 100%;">
                                        <MudText Typo="Typo.body2"
                                                 Style="flex: 1; cursor: pointer; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"
                                                 title="@topic"
                                                 @onclick="async () => await CopyTopicToClipboard(topic)">
                                            @topic
                                        </MudText>
                                        <MudIconButton Size="Size.Small"
                                                       Icon="@Icons.Material.Filled.Close"
                                                       Color="Color.Error"
                                                       title="Unsubscribe"
                                                       OnClick="async () => await UnsubscribeFromTopic(topic)" />
                                    </div>
                                </MudListItem>
                            }
                            <!-- Add new subscription row -->
                            <MudListItem T="string" Dense="true" Class="px-2 py-1">
                                <div style="display: flex; align-items: center; gap: 2px; width: 100%;">
                                    <MudTextField @bind-Value="_topicInput"
                                                  Placeholder="Topic..."
                                                  Variant="Variant.Text"
                                                  Margin="Margin.Dense"
                                                  OnKeyDown="HandleKeyPress"
                                                  Style="flex: 1;"
                                                  Immediate="true"
                                                  Disabled="@(!AppState.IsMqttConnected)" />
                                    <MudIconButton Size="Size.Small"
                                                   Icon="@Icons.Material.Filled.Add"
                                                   Color="Color.Primary"
                                                   title="Subscribe"
                                                   OnClick="async () => await SubscribeToTopic()"
                                                   Disabled="@(string.IsNullOrWhiteSpace(_topicInput) || !AppState.IsMqttConnected)" />
                                </div>
                            </MudListItem>
                        </MudList>
                    </MudCardContent>
                </MudCard>

                <!-- Log card -->
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Log</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">
                                @AppState.Messages.Count
                            </MudChip>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent Class="pa-0">
                        @if (AppState.Messages.Any())
                        {
                            <MudTable Items="@AppState.RecentMessages(20)"
                                      Dense="true" Hover="true" Elevation="0"
                                      FixedHeader="true" Height="300px"
                                      Breakpoint="Breakpoint.None">
                                <HeaderContent>
                                    <MudTh Style="width: 70px;">Time</MudTh>
                                    <MudTh>Topic</MudTh>
                                    <MudTh>Value</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Time" Style="white-space: nowrap; font-size: 0.75rem;">@FormatTimestamp(context.Timestamp)</MudTd>
                                    <MudTd DataLabel="Topic" Style="font-size: 0.75rem; word-break: break-all;">@context.Topic</MudTd>
                                    <MudTd DataLabel="Value" Style="font-size: 0.75rem; font-family: monospace;">@context.Payload</MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Dense="true">
                                Waiting for MQTT messages...
                            </MudAlert>
                        }
                    </MudCardContent>
                </MudCard>

            </MudStack>
        </MudItem>

    </MudGrid>
</MudContainer>

@code {
    private string _topicInput = string.Empty;
    private HashSet<MqttTopicNode> _dataTreeNodes = new();
    private HashSet<TreeItemData<MqttTopicNode>>? _treeItems;
    private bool _isDataExplorerExpanded = false;
    private HashSet<string> _currentTopics = new();
    private List<string> _orderedTopics = new();

    protected override async Task OnInitializedAsync()
    {
        AppState.OnStateChanged += HandleStateChanged;

        if (!MqttInit.IsInitialized)
        {
            await MqttInit.InitializeAsync();
        }

        _orderedTopics = AppState.SubscribedTopics.ToList();
        RefreshDataTree();
    }

    private void RefreshDataTree()
    {
        var allTopics = new Dictionary<string, object>();
        foreach (var topic in AppState.DataCache.GetAllTopics())
        {
            var value = AppState.DataCache.GetValue(topic);
            if (value != null)
            {
                allTopics[topic] = value;
            }
        }

        var newTopicSet = allTopics.Keys.ToHashSet();

        if (!newTopicSet.SetEquals(_currentTopics))
        {
            _currentTopics = newTopicSet;
            _dataTreeNodes = MqttTopicNode.BuildTree(allTopics);
            _treeItems = ConvertToTreeItems(_dataTreeNodes, depth: 0);
        }
        else
        {
            UpdateNodeValues(_dataTreeNodes, allTopics);
        }

        StateHasChanged();
    }

    private void UpdateNodeValues(HashSet<MqttTopicNode> nodes, Dictionary<string, object> topicValues)
    {
        foreach (var node in nodes)
        {
            if (topicValues.TryGetValue(node.FullPath, out var value))
            {
                node.Value = value;
            }

            if (node.Children.Any())
            {
                UpdateNodeValues(node.Children, topicValues);
            }
        }
    }

    private void ToggleDataExplorer()
    {
        _isDataExplorerExpanded = !_isDataExplorerExpanded;
        ExpandAllTreeNodes(_treeItems, _isDataExplorerExpanded);
        StateHasChanged();
    }

    private void ExpandAllTreeNodes(IEnumerable<TreeItemData<MqttTopicNode>>? items, bool expanded)
    {
        if (items == null) return;
        foreach (var item in items)
        {
            item.Expanded = expanded;
            ExpandAllTreeNodes(item.Children, expanded);
        }
    }

    private string GetDataExplorerStyle()
    {
        var maxHeight = _isDataExplorerExpanded ? "800px" : "400px";
        return $"min-height: 250px; max-height: {maxHeight}; overflow-y: auto; transition: max-height 0.3s ease-in-out;";
    }

    private HashSet<TreeItemData<MqttTopicNode>> ConvertToTreeItems(HashSet<MqttTopicNode> nodes, int depth)
    {
        var items = new HashSet<TreeItemData<MqttTopicNode>>();
        foreach (var node in nodes)
        {
            var item = new TreeItemData<MqttTopicNode>
            {
                Value = node,
                Text = node.Name,
                Children = node.Children.Any() ? ConvertToTreeItems(node.Children, depth + 1).ToList() : null,
                Expanded = depth == 0,
            };
            items.Add(item);
        }
        return items;
    }

    private void HandleStateChanged()
    {
        InvokeAsync(() =>
        {
            SyncOrderedTopics();
            RefreshDataTree();
            StateHasChanged();
        });
    }

    private void SyncOrderedTopics()
    {
        var current = AppState.SubscribedTopics;
        _orderedTopics.RemoveAll(t => !current.Contains(t));
        foreach (var topic in current)
        {
            if (!_orderedTopics.Contains(topic))
                _orderedTopics.Add(topic);
        }
    }

    private async Task SubscribeToTopic()
    {
        if (string.IsNullOrWhiteSpace(_topicInput)) return;

        var topic = _topicInput.Trim();
        if (AppState.SubscribedTopics.Contains(topic))
        {
            _topicInput = string.Empty;
            return;
        }

        try
        {
            if (AppState.SignalRService != null)
            {
                await AppState.SignalRService.SubscribeToTopicAsync(topic);
                _orderedTopics.Insert(0, topic);
                _topicInput = string.Empty;
            }
        }
        catch (Exception ex)
        {
            AppState.SetMqttConnectionStatus($"Subscription error: {ex.Message}", AppState.IsMqttConnected);
        }
    }

    private async Task UnsubscribeFromTopic(string topic)
    {
        try
        {
            if (AppState.SignalRService != null)
            {
                await AppState.SignalRService.UnsubscribeFromTopicAsync(topic);
                _orderedTopics.Remove(topic);
            }
        }
        catch (Exception ex)
        {
            AppState.SetMqttConnectionStatus($"Unsubscription error: {ex.Message}", AppState.IsMqttConnected);
        }
    }

    private void HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            InvokeAsync(SubscribeToTopic);
        }
    }

    private async Task CopyTopicToClipboard(string topic)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", topic);
            Snackbar.Add($"Copied: {topic}", Severity.Info, config => { config.VisibleStateDuration = 1500; });
        }
        catch
        {
            Snackbar.Add("Could not copy to clipboard", Severity.Warning);
        }
    }

    private async Task AddTopicToDiagram(string topicPath, string nodeName)
    {
        var diagram = AppState.GetOrCreateDiagram();
        if (diagram.Nodes.Count == 0)
        {
            var savedState = await DiagramService.LoadDiagramAsync();
            if (savedState != null && savedState.Nodes.Count > 0)
            {
                AppState.ResetDiagram();
                diagram = AppState.CreateDiagramFromState(savedState);
            }
        }

        var node = new BlazorApp1.Models.MudNodeModel(
            new Blazor.Diagrams.Core.Geometry.Point(100 + diagram.Nodes.Count * 20, 100))
        {
            Title = nodeName,
            DataTopic = topicPath,
        };
        diagram.Nodes.Add(node);
        Snackbar.Add($"Added '{nodeName}' to diagram", Severity.Success);
    }

    private string FormatTimestamp(DateTime timestamp)
    {
        var local = timestamp.ToLocalTime();
        return local.Date == DateTime.Today
            ? local.ToString("HH:mm:ss")
            : local.ToString("yyyy-MM-dd HH:mm:ss");
    }

    public void Dispose()
    {
        AppState.OnStateChanged -= HandleStateChanged;
    }

    public async ValueTask DisposeAsync()
    {
        Dispose();
        await ValueTask.CompletedTask;
    }
}
