@page "/diagram"
@rendermode InteractiveAuto
@using Blazor.Diagrams;
@using Blazor.Diagrams.Components
@using Blazor.Diagrams.Core.Models

<PageTitle>Diagram</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h3" GutterBottom="true">Diagram Editor</MudText>

    @if (!AppState.IsInteractive || _diagram == null)
    {
        <MudProgressCircular Indeterminate="true" />
        <MudText>Loading...</MudText>
    }
    else
    {
        <MudStack Row="true" Spacing="2">
            <!-- Left Toolbar -->
            <MudPaper Elevation="2" Class="pa-2" Style="width: fit-content;">
                <MudStack Spacing="2">
                    <!-- Add Node Button -->
                    <MudTooltip Text="Add New Node">
                        <MudIconButton Icon="@Icons.Material.Filled.Add"
                                       Color="Color.Primary"
                                       Variant="Variant.Filled"
                                       OnClick="AddNode"
                                       Size="MudBlazor.Size.Large" />
                    </MudTooltip>

                    <!-- Delete Selected Node Button -->
                    <MudTooltip Text="Delete Selected Node">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Variant="Variant.Filled"
                                       OnClick="DeleteSelectedNode"
                                       Disabled="@(!_hasSelectedNode)"
                                       Size="MudBlazor.Size.Large" />
                    </MudTooltip>

                    <!-- Add Port Button with Menu -->
                    <MudMenu AnchorOrigin="Origin.CenterRight"
                             TransformOrigin="Origin.CenterLeft">
                        <ActivatorContent>
                            <MudTooltip Text="Add Port to Selected Node">
                                <MudIconButton Icon="@Icons.Material.Filled.AddCircleOutline"
                                               Color="Color.Secondary"
                                               Variant="Variant.Filled"
                                               Size="MudBlazor.Size.Large"
                                               Disabled="@(!_hasSelectedNode)" />
                            </MudTooltip>
                        </ActivatorContent>
                        <ChildContent>
                            <MudMenuItem OnClick="() => AddPortToSelectedNode(PortAlignment.Top)"
                                         Disabled="@HasPortAlignment(PortAlignment.Top)">
                                <MudStack Row="true" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.ArrowUpward" Size="MudBlazor.Size.Small" />
                                    <MudText>Top Port</MudText>
                                </MudStack>
                            </MudMenuItem>
                            <MudMenuItem OnClick="() => AddPortToSelectedNode(PortAlignment.Right)"
                                         Disabled="@HasPortAlignment(PortAlignment.Right)">
                                <MudStack Row="true" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="MudBlazor.Size.Small" />
                                    <MudText>Right Port</MudText>
                                </MudStack>
                            </MudMenuItem>
                            <MudMenuItem OnClick="() => AddPortToSelectedNode(PortAlignment.Bottom)"
                                         Disabled="@HasPortAlignment(PortAlignment.Bottom)">
                                <MudStack Row="true" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.ArrowDownward" Size="MudBlazor.Size.Small" />
                                    <MudText>Bottom Port</MudText>
                                </MudStack>
                            </MudMenuItem>
                            <MudMenuItem OnClick="() => AddPortToSelectedNode(PortAlignment.Left)"
                                         Disabled="@HasPortAlignment(PortAlignment.Left)">
                                <MudStack Row="true" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="MudBlazor.Size.Small" />
                                    <MudText>Left Port</MudText>
                                </MudStack>
                            </MudMenuItem>
                        </ChildContent>
                    </MudMenu>

                    <!-- Delete Port Button with Menu -->
                    <MudMenu AnchorOrigin="Origin.CenterRight"
                             TransformOrigin="Origin.CenterLeft">
                        <ActivatorContent>
                            <MudTooltip Text="Delete Port from Selected Node">
                                <MudIconButton Icon="@Icons.Material.Filled.RemoveCircleOutline"
                                               Color="Color.Warning"
                                               Variant="Variant.Filled"
                                               Size="MudBlazor.Size.Large"
                                               Disabled="@(!_hasSelectedNode)" />
                            </MudTooltip>
                        </ActivatorContent>
                        <ChildContent>
                            <MudMenuItem OnClick="() => DeletePortFromSelectedNode(PortAlignment.Top)"
                                         Disabled="@(!HasPortAlignment(PortAlignment.Top))">
                                <MudStack Row="true" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.ArrowUpward" Size="MudBlazor.Size.Small" />
                                    <MudText>Top Port</MudText>
                                </MudStack>
                            </MudMenuItem>
                            <MudMenuItem OnClick="() => DeletePortFromSelectedNode(PortAlignment.Right)"
                                         Disabled="@(!HasPortAlignment(PortAlignment.Right))">
                                <MudStack Row="true" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="MudBlazor.Size.Small" />
                                    <MudText>Right Port</MudText>
                                </MudStack>
                            </MudMenuItem>
                            <MudMenuItem OnClick="() => DeletePortFromSelectedNode(PortAlignment.Bottom)"
                                         Disabled="@(!HasPortAlignment(PortAlignment.Bottom))">
                                <MudStack Row="true" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.ArrowDownward" Size="MudBlazor.Size.Small" />
                                    <MudText>Bottom Port</MudText>
                                </MudStack>
                            </MudMenuItem>
                            <MudMenuItem OnClick="() => DeletePortFromSelectedNode(PortAlignment.Left)"
                                         Disabled="@(!HasPortAlignment(PortAlignment.Left))">
                                <MudStack Row="true" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="MudBlazor.Size.Small" />
                                    <MudText>Left Port</MudText>
                                </MudStack>
                            </MudMenuItem>
                        </ChildContent>
                    </MudMenu>

                    <MudDivider />

                    <!-- Save Diagram Button -->
                    <MudTooltip Text="Save Diagram">
                        <MudIconButton Icon="@Icons.Material.Filled.Save"
                                       Color="Color.Success"
                                       Variant="Variant.Filled"
                                       OnClick="SaveDiagram"
                                       Size="MudBlazor.Size.Large" />
                    </MudTooltip>
                </MudStack>
            </MudPaper>

            <!-- Diagram Canvas -->
            <MudPaper Elevation="2" Style="flex: 1; height:600px;">
                <CascadingValue Value="_diagram" IsFixed="true">
                    <DiagramCanvas></DiagramCanvas>
                </CascadingValue>
            </MudPaper>
        </MudStack>
    }
</MudContainer>
