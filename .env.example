# Copy this file to .env and fill in your values.
# .env is git-ignored; .env.example is committed for documentation.
#
# Used by: docker compose

# MQTT broker connection
MqttSettings__Broker=your-mqtt-broker-host
MqttSettings__Port=1883
MqttSettings__Username=
MqttSettings__Password=

# Data storage path inside the container (matches the volume mount in docker-compose.yml)
DiagramStorage__DataDirectory=/app/data
DataProtection__KeysDirectory=/app/data/keys

# Sub-path when the app is served behind a reverse proxy at a sub-path.
# Set to the path segment without slashes, e.g. "rr-dev" for http://host/rr-dev/
# Leave empty for direct root access.
AllowedPathBase=

# Render mode: Auto (InteractiveAuto) or WebAssembly (InteractiveWebAssembly)
RenderMode=Auto
