@page "/mqtt-data"
@using BlazorApp1.Models
@using BlazorApp1.Services
@inject SignalRService SignalRService
@inject ApplicationState AppState
@inject ApplicationStateService AppStateService
@inject MqttInitializationService MqttInit
@inject NavigationManager NavigationManager
@implements IAsyncDisposable
@implements IDisposable

@* rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false)) *@

<PageTitle>MQTT Data</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h3" GutterBottom="true">Real-Time MQTT Data</MudText>

    <MudGrid Spacing="3">
        <!-- Connection Status -->
        <MudItem xs="12">
            <MudAlert Severity="@(AppState.IsMqttConnected ? Severity.Success : Severity.Warning)" 
                      Variant="Variant.Filled" 
                      Dense="true">
                Connection Status: @AppState.MqttConnectionStatus
            </MudAlert>
        </MudItem>

        <!-- Topic Subscription Card -->
        <MudItem xs="12" md="6">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Topic Subscriptions</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudTextField @bind-Value="_topicInput"
                                      Label="MQTT Topic"
                                      Variant="Variant.Outlined"
                                      Placeholder="e.g., sensor/temperature"
                                      OnKeyDown="HandleKeyPress"
                                      Disabled="@(!AppState.IsMqttConnected)"
                                      Style="flex-grow: 1;" />

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.AddCircle"
                                   OnClick="SubscribeToTopic"
                                   Disabled="@(!AppState.IsMqttConnected)"
                                   Class="mt-2">
                            Subscribe
                        </MudButton>
                    </MudStack>

                    @if (AppState.SubscribedTopics.Any())
                    {
                        <MudDivider Class="my-3" />
                        <MudList T="string" Dense="true">
                            @foreach (var topic in AppState.SubscribedTopics)
                            {
                                <MudListItem T="string">
                                    <div class="d-flex justify-space-between align-center" style="width: 100%;">
                                        <MudText>@topic</MudText>
                                        <MudButton Size="Size.Small"
                                                   Variant="Variant.Filled"
                                                   Color="Color.Error"
                                                   StartIcon="@Icons.Material.Filled.RemoveCircle"
                                                   OnClick="() => UnsubscribeFromTopic(topic)">
                                            Unsubscribe
                                        </MudButton>
                                    </div>
                                </MudListItem>
                            }
                        </MudList>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-3">
                            No active subscriptions. Enter a topic above to subscribe.
                        </MudText>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Data Cache Explorer -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Data Cache Explorer</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip T="string" Size="Size.Small" Color="Color.Success">
                            @AppState.DataCache.GetAllTopics().Count() Topics
                        </MudChip>
                        <MudIconButton Icon="@(_isDataExplorerExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                       Color="Color.Default"
                                       OnClick="ToggleDataExplorer"
                                       Size="Size.Small" 
                                       Title="@(_isDataExplorerExpanded ? "Collapse" : "Expand")" />
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Secondary"
                                   StartIcon="@Icons.Material.Filled.Refresh"
                                   OnClick="RefreshDataTree"
                                   Size="Size.Small">
                            Refresh
                        </MudButton>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Style="@GetDataExplorerStyle()">

                    @if (_treeItems != null && _treeItems.Any())
                    {
                        <MudTreeView T="MqttTopicNode" 
                                     Items="_treeItems" 
                                     Dense="true"
                                     Hover="true"
                                     ExpandOnClick="true">
                            <ItemTemplate Context="item">
                                <MudTreeViewItem @bind-Expanded="@item.Expanded" 
                                                 Items="@item.Children" 
                                                 Value="@item.Value"
                                                 Icon="@item.Value.Icon"
                                                 IconColor="@item.Value.IconColor"
                                                 Text="@item.Text">
                                    <BodyContent>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudText Typo="Typo.body2">@item.Value.Name</MudText>
                                            @if (item.Value.HasValue)
                                            {
                                                <MudChip T="string" 
                                                         Size="Size.Small" 
                                                         Color="@(item.Value.HasChildren ? Color.Primary : Color.Success)" 
                                                         Variant="Variant.Filled">
                                                    @item.Value.Value?.ToString()
                                                </MudChip>
                                            }
                                            @if (!item.Value.HasValue && !item.Value.HasChildren)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                                                    No data
                                                </MudChip>
                                            }
                                        </MudStack>
                                    </BodyContent>
                                </MudTreeViewItem>
                            </ItemTemplate>
                        </MudTreeView>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">
                            No data in cache yet. Subscribe to topics to see data here.
                        </MudAlert>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Messages Display -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Recent Messages</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip T="string" Size="Size.Small" Color="Color.Info">
                            @AppState.Messages.Count Total
                        </MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    @if (AppState.Messages.Any())
                    {
                        <MudPaper Elevation="0" Class="pa-2" Style="max-height: 400px; overflow-y: auto;">
                            @foreach (var message in AppState.Messages.OrderByDescending(m => m.Timestamp).Take(10))
                            {
                                <MudPaper Elevation="1" Class="pa-3 mb-2">
                                    <MudGrid Spacing="1">
                                        <MudItem xs="12">
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @message.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss.fff")
                                            </MudText>
                                        </MudItem>
                                        <MudItem xs="12">
                                            <MudText Typo="Typo.body2">
                                                <strong>Topic:</strong> @message.Topic
                                            </MudText>
                                        </MudItem>
                                        <MudItem xs="12">
                                            <MudText Typo="Typo.body2" Style="word-break: break-all;">
                                                <strong>Payload:</strong> @message.Payload
                                            </MudText>
                                        </MudItem>
                                    </MudGrid>
                                </MudPaper>
                            }
                        </MudPaper>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                            Showing last 10 messages
                        </MudText>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">
                            Waiting for MQTT messages...
                        </MudAlert>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private string _topicInput = string.Empty;
    private HashSet<MqttTopicNode> _dataTreeNodes = new();
    private HashSet<TreeItemData<MqttTopicNode>>? _treeItems;
    private bool _isDataExplorerExpanded = false;
    private HashSet<string> _currentTopics = new(); // Track topic structure changes

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to state changes with proper async handling
        AppState.OnStateChanged += HandleStateChanged;

        // Ensure MQTT is initialized (will skip if already done)
        if (!MqttInit.IsInitialized)
        {
            await MqttInit.InitializeAsync();
        }

        // The SignalR service and subscriptions are already set up by MqttInitializationService
        // Just ensure we have the event handlers connected for this page
        if (AppState.SignalRService != null)
        {
            // Note: Event handlers are already set up by MqttInitializationService
            // This page can now just display the data
        }

        // Build initial data tree
        RefreshDataTree();
    }

    private void RefreshDataTree()
    {
        var allTopics = new Dictionary<string, object>();
        foreach (var topic in AppState.DataCache.GetAllTopics())
        {
            var value = AppState.DataCache.GetValue(topic);
            if (value != null)
            {
                allTopics[topic] = value;
            }
        }

        var newTopicSet = allTopics.Keys.ToHashSet();

        // Only rebuild tree if topic structure changed
        if (!newTopicSet.SetEquals(_currentTopics))
        {
            _currentTopics = newTopicSet;
            _dataTreeNodes = MqttTopicNode.BuildTree(allTopics);
            _treeItems = ConvertToTreeItems(_dataTreeNodes);
        }
        else
        {
            // Just update values in existing nodes
            UpdateNodeValues(_dataTreeNodes, allTopics);
        }

        StateHasChanged();
    }

    private void UpdateNodeValues(HashSet<MqttTopicNode> nodes, Dictionary<string, object> topicValues)
    {
        foreach (var node in nodes)
        {
            // Update value if this node represents a complete topic
            if (topicValues.TryGetValue(node.FullPath, out var value))
            {
                node.Value = value;
            }

            // Recursively update children
            if (node.Children.Any())
            {
                UpdateNodeValues(node.Children, topicValues);
            }
        }
    }

    private void ToggleDataExplorer()
    {
        _isDataExplorerExpanded = !_isDataExplorerExpanded;
        StateHasChanged();
    }

    private string GetDataExplorerStyle()
    {
        var minHeight = "250px";
        var maxHeight = _isDataExplorerExpanded ? "800px" : "250px";
        return $"min-height: {minHeight}; max-height: {maxHeight}; overflow-y: auto; transition: max-height 0.3s ease-in-out;";
    }

    private HashSet<TreeItemData<MqttTopicNode>> ConvertToTreeItems(HashSet<MqttTopicNode> nodes)
    {
        var items = new HashSet<TreeItemData<MqttTopicNode>>();

        foreach (var node in nodes)
        {
            var item = new TreeItemData<MqttTopicNode>
            {
                Value = node,
                Text = node.Name,
                Children = node.Children.Any() ? ConvertToTreeItems(node.Children).ToList() : null,
                Expanded = false // Let MudTreeView manage this
            };

            items.Add(item);
        }

        return items;
    }

    private async Task RestoreSubscriptionsAsync()
    {
        // This is now handled by MqttInitializationService on app startup
        // Keeping this method for backwards compatibility but it won't be called
    }

    private void HandleStateChanged()
    {
        // Marshal to UI thread and refresh tree
        InvokeAsync(() =>
        {
            RefreshDataTree();
            StateHasChanged();
        });
    }

    private async Task SubscribeToTopic()
    {
        if (string.IsNullOrWhiteSpace(_topicInput))
            return;

        var topic = _topicInput.Trim();

        if (AppState.SubscribedTopics.Contains(topic))
            return;

        try
        {
            if (AppState.SignalRService != null)
            {
                await AppState.SignalRService.SubscribeToTopicAsync(topic);
                _topicInput = string.Empty;
            }
        }
        catch (Exception ex)
        {
            AppState.SetMqttConnectionStatus($"Subscription error: {ex.Message}", AppState.IsMqttConnected);
        }
    }

    private async Task UnsubscribeFromTopic(string topic)
    {
        try
        {
            if (AppState.SignalRService != null)
            {
                await AppState.SignalRService.UnsubscribeFromTopicAsync(topic);
            }
        }
        catch (Exception ex)
        {
            AppState.SetMqttConnectionStatus($"Unsubscription error: {ex.Message}", AppState.IsMqttConnected);
        }
    }

    private void ClearMessages()
    {
        AppState.ClearMessages();
    }

    private void HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            InvokeAsync(SubscribeToTopic);
        }
    }

    private void HandleDataReceived(MqttDataMessage message)
    {
        // This handler is no longer needed here as it's handled by MqttInitializationService
        // Keeping for backwards compatibility
    }

    private async void HandleSubscriptionConfirmed(string topic)
    {
        // This handler is no longer needed here as it's handled by MqttInitializationService
        // Keeping for backwards compatibility
    }

    private async void HandleUnsubscriptionConfirmed(string topic)
    {
        // This handler is no longer needed here as it's handled by MqttInitializationService
        // Keeping for backwards compatibility
    }

    public void Dispose()
    {
        AppState.OnStateChanged -= HandleStateChanged;

        if (AppState.SignalRService != null)
        {
            AppState.SignalRService.OnDataReceived -= HandleDataReceived;
            AppState.SignalRService.OnSubscriptionConfirmed -= HandleSubscriptionConfirmed;
            AppState.SignalRService.OnUnsubscriptionConfirmed -= HandleUnsubscriptionConfirmed;
        }
    }

    public async ValueTask DisposeAsync()
    {
        Dispose();
        // Don't dispose SignalRService here as it's shared across pages
    }
}
