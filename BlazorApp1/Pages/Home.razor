@page "/"
@inject BlazorApp1.Services.DiagramStateService DiagramState

<PageTitle>Home</PageTitle>

<MudStack Spacing="2" Class="pa-2">
<MudCard>
    <MudCardContent>
        <MudText Typo="Typo.h4" GutterBottom="true">Hello, world!</MudText>
        <MudText Class="">A app for Blazor experiments</MudText>
        <MudText>
            Using the excellent
            <MudLink Target="_blank" Href="https://mudblazor.com">MudBlazor</MudLink>
            and <MudLink Target="_blank" Href="https://blazor-diagrams.zhaytam.com/">Blazor.Diagrams</MudLink>
        </MudText>
    </MudCardContent>
</MudCard>

<MudCard Outlined="true" >
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">Counter</MudText>
        @if (DiagramState.IsInteractive)
        {
            <MudText>Current count: @DiagramState.Counter</MudText>
        }
        else
        {
            <MudText>Loading...</MudText>
        }
    </MudCardContent>
    <MudCardActions>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" @onclick="IncrementCount" Disabled="!DiagramState.IsInteractive">Click me</MudButton>
    </MudCardActions>
</MudCard>
</MudStack>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            DiagramState.SetInteractive();
            StateHasChanged();
        }
        await base.OnAfterRenderAsync(firstRender);
    }

    private void IncrementCount()
    {
        DiagramState.Counter++;
    }
}
