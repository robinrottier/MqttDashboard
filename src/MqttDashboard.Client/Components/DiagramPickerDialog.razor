@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Open Dashboard</MudText>
    </TitleContent>
    <DialogContent>
        <MudList T="string" SelectionMode="SelectionMode.SingleSelection" @bind-SelectedValue="_selected" Dense="true">
            @foreach (var name in DiagramNames)
            {
                <MudListItem Value="@name" Text="@name" />
            }
        </MudList>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit"
                   Disabled="@string.IsNullOrEmpty(_selected)">Open</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public List<string> DiagramNames { get; set; } = [];

    private string? _selected;

    private void Submit() => MudDialog.Close(DialogResult.Ok(_selected ?? string.Empty));
    private void Cancel() => MudDialog.Cancel();
}
