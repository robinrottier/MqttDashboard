@using MqttDashboard.Models
@using MqttDashboard.Services
@using Blazor.Diagrams.Components.Renderers
@inherits BaseNodeWithDataWidget<GaugeNodeModel>

<MudTooltip Delay="500" Arrow="true" Placement="Placement.Top">
    <TooltipContent>
        @if (!string.IsNullOrEmpty(Node.DataTopic))
        {
            <div>
                <strong>Topic:</strong> @Node.DataTopic<br/>
                <strong>Value:</strong> @(Node.DataValue?.ToString() ?? "—")<br/>
                <strong>Updated:</strong> @(Node.DataLastUpdated.HasValue ? Node.DataLastUpdated.Value.ToString("HH:mm:ss") : "—")
            </div>
        }
        else { <span>No data topic configured</span> }
    </TooltipContent>
    <ChildContent>
        <div style="@ContainerStyle()"
             class=@("pa-1 default-node gauge-node"+(Node.Group != null ? " grouped" : "")+(Node.Selected ? " selected" : ""))
             @ondblclick="OnDoubleClick">
            <div style="@OuterFlexStyle()">
                @if (ShowTitleFirst())
                {
                    <div style="@TitleDivStyle()">@Node.Title</div>
                }
                <div style="flex:1;min-height:0;min-width:0;">
                    <svg viewBox="0 0 120 75" style="width:100%;height:auto;display:block;">
                        <!-- Background arc (full 180° semicircle) -->
                        <path d="M 10 65 A 55 55 0 0 1 110 65"
                              stroke="rgba(128,128,128,0.25)" stroke-width="10" fill="none" stroke-linecap="round"/>
                        <!-- Value arc -->
                        @{
                            var arcPath = BuildValueArcPath();
                        }
                        @if (!string.IsNullOrEmpty(arcPath))
                        {
                            <path d="@arcPath"
                                  stroke="@GetArcColor()" stroke-width="10" fill="none" stroke-linecap="round"/>
                        }
                        <!-- Value text and labels rendered via MarkupString to avoid Razor <text> parsing conflict -->
                        @RenderSvgLabels()
                    </svg>
                    @if (!string.IsNullOrEmpty(Node.Text))
                    {
                        <div style="text-align:center;font-size:0.75rem;padding:1px 4px;word-break:break-word;">@FormatText()</div>
                    }
                </div>
                @if (!ShowTitleFirst() && !string.IsNullOrEmpty(Node.Title))
                {
                    <div style="@TitleDivStyle()">@Node.Title</div>
                }
            </div>
            @foreach (var port in Node.Ports)
            {
                <PortRenderer @key="port" Port="port" Style="@PortStyle(port as MudPortModel)" />
            }
        </div>
    </ChildContent>
</MudTooltip>

@code {
    private double _percent = 0;

    protected override void OnInitialized()
    {
        Node.MinimumDimensions = new(80, 80);
        if (Node.Size == null || Node.Size.Width < 80 || Node.Size.Height < 80)
            Node.Size = new(120, 100);
        base.OnInitialized();
    }

    protected override void OnData1Updated() => UpdatePercent();

    private void UpdatePercent()
    {
        if (Node.DataValue == null) { _percent = 0; return; }
        if (double.TryParse(Node.DataValue.ToString(), out var d))
        {
            var range = Node.MaxValue - Node.MinValue;
            _percent = range == 0 ? 0 : Math.Clamp((d - Node.MinValue) / range, 0.0, 1.0);
        }
    }

    private string BuildValueArcPath()
    {
        var origin = Node.ArcOrigin ?? Node.MinValue;
        var range = Node.MaxValue - Node.MinValue;

        // With ArcOrigin: draw from origin point to current value point
        if (Node.ArcOrigin.HasValue && range != 0)
        {
            var originPercent = Math.Clamp((origin - Node.MinValue) / range, 0.0, 1.0);
            var valuePercent = Math.Clamp(_percent, 0.0, 1.0);

            if (Math.Abs(valuePercent - originPercent) < 0.001) return "";

            var originAngle = (1.0 - originPercent) * Math.PI;
            var valueAngle = (1.0 - valuePercent) * Math.PI;

            var ox = 60 + 55 * Math.Cos(originAngle);
            var oy = 65 - 55 * Math.Sin(originAngle);
            var vx = 60 + 55 * Math.Cos(valueAngle);
            var vy = 65 - 55 * Math.Sin(valueAngle);

            // sweep=1 clockwise (value > origin = arc going right), sweep=0 counter-clockwise
            var sweep = valuePercent > originPercent ? 1 : 0;
            return $"M {ox:F2} {oy:F2} A 55 55 0 0 {sweep} {vx:F2} {vy:F2}";
        }

        // Default: arc from left end (MinValue) to current value
        var p = Math.Clamp(_percent, 0.0, 1.0);
        if (p >= 0.9999) return "M 5 65 A 55 55 0 0 1 115 65";
        var angleDeg = 180.0 - 180.0 * p;
        var angleRad = angleDeg * Math.PI / 180.0;
        var x = 60 + 55 * Math.Cos(angleRad);
        var y = 65 - 55 * Math.Sin(angleRad);
        var largeArc = p > 0.5 ? 1 : 0;
        return $"M 5 65 A 55 55 0 {largeArc} 1 {x:F2} {y:F2}";
    }

    private string GetArcColor()
    {
        if (Node.ColorThresholds.Count > 0 && Node.DataValue != null &&
            double.TryParse(Node.DataValue.ToString(), out var dThresh))
        {
            var origin = Node.ArcOrigin ?? Node.MinValue;
            var distance = Math.Abs(dThresh - origin);
            string? color = null;
            foreach (var t in Node.ColorThresholds)
            {
                if (t.Direction == ">=" && distance >= t.Value) color = t.Color;
                else if (t.Direction == "<=" && distance <= t.Value) color = t.Color;
            }
            if (color != null) return color;
        }
        return _percent switch
        {
            >= 0.8 => "var(--mud-palette-error)",
            >= 0.6 => "var(--mud-palette-warning)",
            _      => "var(--mud-palette-primary)"
        };
    }

    private MarkupString RenderSvgLabels()
    {
        var fontSize = Node.FontSize.HasValue ? Node.FontSize.Value : 16;
        var value = System.Net.WebUtility.HtmlEncode(FormatValue());
        var sb = new System.Text.StringBuilder();

        // Draw tick mark at ArcOrigin (if set)
        var tickValue = Node.ArcOrigin;
        if (tickValue.HasValue)
        {
            var range = Node.MaxValue - Node.MinValue;
            if (range != 0)
            {
                var mp = Math.Clamp((tickValue.Value - Node.MinValue) / range, 0.0, 1.0);
                var θ = (1.0 - mp) * Math.PI;
                var cosθ = Math.Cos(θ); var sinθ = Math.Sin(θ);
                var x1 = 60 + 48 * cosθ; var y1 = 65 - 48 * sinθ;
                var x2 = 60 + 62 * cosθ; var y2 = 65 - 62 * sinθ;
                sb.Append($"<line x1=\"{x1:F1}\" y1=\"{y1:F1}\" x2=\"{x2:F1}\" y2=\"{y2:F1}\" stroke=\"rgba(128,128,128,0.8)\" stroke-width=\"2\" stroke-linecap=\"round\"/>");
            }
        }

        sb.Append($"<text x=\"60\" y=\"60\" text-anchor=\"middle\" dominant-baseline=\"auto\" font-size=\"{fontSize}\" font-weight=\"bold\" fill=\"currentColor\">{value}</text>");
        if (!string.IsNullOrEmpty(Node.Unit))
            sb.Append($"<text x=\"60\" y=\"72\" text-anchor=\"middle\" font-size=\"9\" fill=\"currentColor\" opacity=\"0.7\">{System.Net.WebUtility.HtmlEncode(Node.Unit)}</text>");
        sb.Append($"<text x=\"8\" y=\"75\" text-anchor=\"start\" font-size=\"8\" fill=\"currentColor\" opacity=\"0.5\">{Node.MinValue}</text>");
        sb.Append($"<text x=\"112\" y=\"75\" text-anchor=\"end\" font-size=\"8\" fill=\"currentColor\" opacity=\"0.5\">{Node.MaxValue}</text>");
        return new MarkupString(sb.ToString());
    }

    private string FormatValue()
    {
        if (Node.DataValue == null) return "—";
        if (double.TryParse(Node.DataValue.ToString(), out var d))
            return d.ToString("G4");
        return Node.DataValue.ToString() ?? "—";
    }

    private string TitlePos => string.IsNullOrEmpty(Node.TitlePosition) ? "Above" : Node.TitlePosition;
    private bool ShowTitleFirst() => (TitlePos == "Above" || TitlePos == "Left") && !string.IsNullOrEmpty(Node.Title);
    private string OuterFlexStyle() => TitlePos switch
    {
        "Left"  => "display:flex;flex-direction:row;align-items:center;height:100%;",
        "Right" => "display:flex;flex-direction:row;align-items:center;height:100%;",
        _       => "display:flex;flex-direction:column;height:100%;"
    };
    private string TitleDivStyle() => TitlePos switch
    {
        "Left" or "Right" => "text-align:center;font-size:0.75rem;font-weight:500;padding:2px 4px;max-width:4rem;word-wrap:break-word;",
        _ => "text-align:center;font-size:0.75rem;font-weight:500;padding:2px 4px 0;"
    };
}
