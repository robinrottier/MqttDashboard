@using MqttDashboard.Models
@using MqttDashboard.Services
@using Blazor.Diagrams.Components.Renderers
@inject ISignalRService SignalRService
@inherits BaseNodeWithDataWidget<SwitchNodeModel>

<MudTooltip Delay="500" Arrow="true" Placement="Placement.Top">
    <TooltipContent>
        @if (!string.IsNullOrEmpty(Node.DataTopic))
        {
            <div>
                <strong>Topic:</strong> @Node.DataTopic<br/>
                <strong>Value:</strong> @(Node.DataValue?.ToString() ?? "—")<br/>
                <strong>Updated:</strong> @(Node.DataLastUpdated.HasValue ? Node.DataLastUpdated.Value.ToString("HH:mm:ss") : "—")
            </div>
        }
        else { <span>No data topic configured</span> }
    </TooltipContent>
    <ChildContent>
        <div style="@ContainerStyle()"
             class=@("pa-1 default-node switch-node"+(Node.Group != null ? " grouped" : "")+(Node.Selected ? " selected" : ""))
             @ondblclick="OnDoubleClick">
            <div style="@OuterFlexStyle()">
                @if (ShowTitleFirst())
                {
                    <div style="@TitleDivStyle()">@Node.Title</div>
                }
                <div style="flex:1;min-height:0;min-width:0;display:flex;align-items:center;justify-content:center;">
                    @if (Node.SwitchStyle == "Compact")
                    {
                        <div style="display:flex;flex-direction:row;align-items:center;justify-content:space-between;gap:4px;padding:2px 4px;width:100%;">
                            <span style="font-size:0.75rem;font-weight:500;color:@(_isOn ? "var(--mud-palette-success-text)" : "currentColor");min-width:2.5rem;display:inline-block;text-align:center;">
                                @(_isOn ? Node.OnText : Node.OffText)
                            </span>
                            <MudIconButton Icon="@(_isOn ? Icons.Material.Filled.ToggleOn : Icons.Material.Filled.ToggleOff)"
                                           Color="@(_isOn ? Color.Success : Color.Default)"
                                           Size="Size.Medium" Style="padding:0;" OnClick="Toggle"
                                           Disabled="Node.IsReadOnly" />
                        </div>
                    }
                    else if (Node.SwitchStyle == "IconOnly")
                    {
                        <MudIconButton Icon="@(_isOn ? Icons.Material.Filled.ToggleOn : Icons.Material.Filled.ToggleOff)"
                                       Color="@(_isOn ? Color.Success : Color.Default)"
                                       Size="Size.Large" Style="padding:0;" OnClick="Toggle"
                                       Disabled="Node.IsReadOnly" />
                    }
                    else
                    {
                        <div style="display:flex;flex-direction:column;align-items:center;gap:4px;">
                            <MudChip T="string" Color="@(_isOn ? Color.Success : Color.Default)" Size="Size.Small" Style="pointer-events:none;">
                                @(_isOn ? Node.OnText : Node.OffText)
                            </MudChip>
                            @if (!string.IsNullOrEmpty(Node.PublishTopic) || !string.IsNullOrEmpty(Node.DataTopic))
                            {
                                <MudIconButton Icon="@(_isOn ? Icons.Material.Filled.ToggleOn : Icons.Material.Filled.ToggleOff)"
                                               Color="@(_isOn ? Color.Success : Color.Default)"
                                               Size="Size.Large" Style="padding:0;" OnClick="Toggle"
                                               Disabled="Node.IsReadOnly" />
                            }
                        </div>
                    }
                </div>
                @if (!ShowTitleFirst() && !string.IsNullOrEmpty(Node.Title))
                {
                    <div style="@TitleDivStyle()">@Node.Title</div>
                }
            </div>
            @foreach (var port in Node.Ports)
            {
                <PortRenderer @key="port" Port="port" Style="@PortStyle(port as MudPortModel)" />
            }
        </div>
    </ChildContent>
</MudTooltip>

@code {
    private bool _isOn = false;

    protected override void OnInitialized()
    {
        Node.MinimumDimensions = new(60, 60);
        if (Node.Size == null || Node.Size.Width < 60 || Node.Size.Height < 60)
            Node.Size = new(100, 80);
        base.OnInitialized();
    }

    protected override void OnData1Updated() => UpdateState();

    private void UpdateState()
    {
        var val = Node.DataValue?.ToString() ?? "";
        var onVal = string.IsNullOrEmpty(Node.OnValue) ? "1" : Node.OnValue;
        _isOn = val.Equals(onVal, StringComparison.OrdinalIgnoreCase)
             || val == "true" || val == "on";
    }

    private async Task Toggle()
    {
        if (Node.IsReadOnly) return;
        var publishTopic = !string.IsNullOrEmpty(Node.PublishTopic) ? Node.PublishTopic : Node.DataTopic;
        if (string.IsNullOrEmpty(publishTopic)) return;
        var payload = _isOn
            ? (string.IsNullOrEmpty(Node.OffValue) ? "0" : Node.OffValue)
            : (string.IsNullOrEmpty(Node.OnValue) ? "1" : Node.OnValue);
        await SignalRService.PublishMessageAsync(publishTopic, payload);
    }

    private string TitlePos => string.IsNullOrEmpty(Node.TitlePosition) ? "Above" : Node.TitlePosition;
    private bool ShowTitleFirst() => (TitlePos == "Above" || TitlePos == "Left") && !string.IsNullOrEmpty(Node.Title);
    private string OuterFlexStyle() => TitlePos switch
    {
        "Left"  => "display:flex;flex-direction:row;align-items:center;height:100%;",
        "Right" => "display:flex;flex-direction:row;align-items:center;height:100%;",
        _       => "display:flex;flex-direction:column;height:100%;"
    };
    private string TitleDivStyle() => TitlePos switch
    {
        "Left" or "Right" => "text-align:center;font-size:0.75rem;font-weight:500;padding:2px 4px;max-width:4rem;word-wrap:break-word;",
        _ => "text-align:center;font-size:0.75rem;font-weight:500;padding:2px 4px 0;"
    };
}
